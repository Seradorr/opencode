{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "disabled_providers": [],
  "default_agent": "build",
  "small_model": "openai2/Qwen3.5-35B-A3B",
  "provider": {
    "openai2": {
      "name": "CustomModels",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "GLM-4.7-FP8": {
          "name": "GLM Hard",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "options": {
            "frequency_penalty": 0.2,
            "presence_penalty": 0.1,
            "top_p": 1.0
          }
        },
        "Kimi-K2.5": {
          "name": "Kimi",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "options": {
            "top_p": 1.0
          }
        },
        "Qwen3.5-35B-A3B": {
          "name": "Qwen Fast",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "options": {
            "top_p": 1.0
          }
        },
        "Qwen3.5-397B-A17B-FP8": {
          "name": "Qwen Hard",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "options": {
            "top_p": 1.0
          }
        },
        "dall-e-3": {
          "name": "ImageGen"
        }
      },
      "options": {
        "baseURL": "https://api.example.com/v1"
      }
    }
  },
  "instructions": ["./.opencode/*.md"],
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git push*": "ask",
      "git reset --hard*": "ask",
      "git clean*": "ask"
    }
  },
  "agent": {
    "build": {
      "description": "Ana geliştirme ajanı. Kod yazar, debug eder, dosya düzenler. Tam araç erişimi.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.7,
      "prompt": "./.opencode/agents/build.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "description": "Analiz ve planlama ajanı. Kod yazmadan mimari analiz eder, uygulama planı sunar.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.6,
      "prompt": "./.opencode/agents/plan.md",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "review": {
      "description": "Kod inceleme ajanı. Salt-okunur analiz, anti-pattern ve güvenlik tespiti yapar.",
      "mode": "subagent",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.3,
      "prompt": "./.opencode/agents/review.md",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow"
        }
      }
    },
    "refactor": {
      "description": "Kod iyileştirme ajanı. Davranışı bozmadan mevcut kodu modernize eder ve temizler.",
      "mode": "subagent",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.7,
      "prompt": "./.opencode/agents/refactor.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "docs": {
      "description": "Teknik dokümantasyon ajanı. Koddan okunabilir ve hedef kitleye uygun doküman üretir.",
      "mode": "subagent",
      "model": "openai2/Kimi-K2.5",
      "temperature": 0.6,
      "prompt": "./.opencode/agents/docs.md",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git log*": "allow"
        }
      }
    },
    "test": {
      "description": "Test yazma ajanı. Birim, entegrasyon ve testbench testleri üretir.",
      "mode": "subagent",
      "model": "openai2/GLM-4.7-FP8",
      "temperature": 0.4,
      "prompt": "./.opencode/agents/test.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "fast": {
      "description": "Hızlı görevler için hafif ajan. Basit kodlama, kısa sorular, snippet üretimi.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-35B-A3B",
      "temperature": 0.7,
      "prompt": "./.opencode/agents/fast.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  }
}
