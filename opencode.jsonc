{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "disabled_providers": [],
  "default_agent": "build",
  "small_model": "openai2/Qwen3.5-35B-A3B",
  "provider": {
    "openai2": {
      "name": "CustomModels",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "GLM-4.7-FP8": {
          "name": "GLM Hard",
          "max_tokens": 32768,
          "frequency_penalty": 0.0,
          "presence_penalty": 0.0
        },
        "Kimi-K2.5": {
          "name": "Kimi",
          "max_tokens": 32768,
          "top_p": 0.8
        },
        "Qwen3.5-35B-A3B": {
          "name": "Qwen Fast",
          "max_tokens": 32768,
          "top_p": 0.8
        },
        "Qwen3.5-397B-A17B-FP8": {
          "name": "Qwen Hard",
          "max_tokens": 32768,
          "top_p": 0.8
        },
        "dall-e-3": {
          "name": "ImageGen",
          "top_p": 1.0
        }
      },
      "options": {
        "baseURL": "https://api.example.com/v1"
      }
    }
  },
  "instructions": ["./.opencode/*.md"],
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git push*": "ask",
      "git reset --hard*": "ask",
      "git clean*": "ask"
    }
  },
  "agent": {
    "build": {
      "description": "Full-stack geliştirme uzmanı. FPGA (VHDL/Verilog), Embedded C/C++, Python, C#/.NET, teknik dokümantasyon ve modern yazılım geliştirme pratiklerinde uzman. Kod yazar, debug eder ve mimari kararlar alır.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.7,
      "prompt": "./.opencode/agents/build.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "description": "Sistem mimarisi ve analiz uzmanı. Karmaşık projeleri yapılandırır, teknik gereksinimleri analiz eder, mimari öneriler sunar. RTL tasarım, gömülü sistemler, uygulama geliştirme ve entegrasyon projelerinde planlama yapar.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.6,
      "prompt": "./.opencode/agents/plan.md",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "review": {
      "description": "Kod kalitesi ve teknik inceleme uzmanı. VHDL/Verilog, C/C++, C#, Python ve dokümantasyon için best practice, anti-pattern, güvenlik ve performans analizi yapar.",
      "mode": "subagent",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.3,
      "prompt": "./.opencode/agents/review.md",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow"
        }
      }
    },
    "refactor": {
      "description": "Kod optimizasyon ve yeniden yapılandırma uzmanı. Legacy kodu modernize eder, teknik borcu azaltır, FPGA timing closure, gömülü C optimizasyonu, .NET async/await patternleri ve Python performans iyileştirmeleri yapar.",
      "mode": "subagent",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.7,
      "prompt": "./.opencode/agents/refactor.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "docs": {
      "description": "Teknik dokümantasyon ve bilgi yönetimi uzmanı. FPGA IP dokümantasyonu, gömülü C API referansları, C#/.NET kütüphane dokümantasyonu, Python modül dokümanları, README dosyaları ve teknik spesifikasyonlar yazar.",
      "mode": "subagent",
      "model": "openai2/Kimi-K2.5",
      "temperature": 0.6,
      "prompt": "./.opencode/agents/docs.md",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "git log*": "allow"
        }
      }
    },
    "test": {
      "description": "Test mühendisliği ve kalite güvencesi uzmanı. FPGA testbenchleri (VHDL/Verilog), gömülü C unit testleri, C# xUnit/NUnit testleri, Python pytest/modüller ve entegrasyon testleri yazar.",
      "mode": "subagent",
      "model": "openai2/GLM-4.7-FP8",
      "temperature": 0.4,
      "prompt": "./.opencode/agents/test.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "fast": {
      "description": "Hızlı kod yazma ve basit görevler için optimize edilmiş hafif model. Günlük kodlama, hızlı debug, basit refactor işlemleri için kullanılır.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-35B-A3B",
      "temperature": 0.7,
      "prompt": "./.opencode/agents/fast.md",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  }
}
