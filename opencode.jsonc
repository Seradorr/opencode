{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai2/Qwen3.5-397B-A17B-FP8",
  "small_model": "openai2/Qwen3.5-35B-A3B-FP8",

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "enabled_providers": ["openai2"],

  "provider": {
    "openai2": {
      "name": "CustomModels",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        // Replace with your real endpoint before use.
        "baseURL": "https://api.example.com/v1",
        // Replace with your real API key before use.
        "apiKey": "REPLACE_WITH_REAL_API_KEY"
      },
      "models": {
        "Qwen3.5-397B-A17B-FP8": {
          "name": "Qwen_HARD",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "Qwen3.5-35B-A3B-FP8": {
          "name": "Qwen_SOFT",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "Kimi-K2.5": {
          "name": "Kimi_HARD",
          "reasoning": true,
          "tool_call": true,
          "temperature": false,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "GLM-4.7-FP8": {
          "name": "GLM_HARD",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },

  "instructions": ["./instructions/*.md"],

  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git commit*": "ask",
      "git push*": "ask"
    },
    "webfetch": "deny",
    "external_directory": "ask"
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "bin/**",
      "obj/**",
      ".venv/**",
      "__pycache__/**",
      "coverage/**"
    ]
  },

  "share": "disabled",
  "autoupdate": false,

  "agent": {
    "build": {
      "description": "Primary implementation agent for coding, debugging, and file edits.",
      "mode": "primary",
      "model": "openai2/Qwen3.5-397B-A17B-FP8",
      "temperature": 0.25,
      "prompt": "{file:./prompts/build.md}"
    },
    "plan": {
      "description": "Primary planning agent for architecture, repo analysis, and decision-complete plans.",
      "mode": "primary",
      "model": "openai2/Kimi-K2.5",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "explore": {
      "description": "Read-only exploration subagent for broad repo scans and fact gathering.",
      "mode": "subagent",
      "model": "openai2/GLM-4.7-FP8",
      "temperature": 0.2,
      "prompt": "{file:./prompts/explore.md}",
      "permission": {
        "edit": "deny"
      }
    },
    "general": {
      "disable": true
    }
  }
}
